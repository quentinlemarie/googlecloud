# Google OAuth 2.0 client credentials (https://console.cloud.google.com/apis/credentials)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_APP_ID=

# Google API key (used for Drive Picker)
VITE_GOOGLE_API_KEY=

# Gemini API key (https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=

# Google Cloud project ID (used for GCP Error Reporting)
VITE_GCP_PROJECT_ID=

# Google Cloud Storage bucket name
VITE_GCS_BUCKET=

# Optional: Google Drive folder ID for the recordings picker (use the folder's Drive ID, not its name)
VITE_REC_FOLDER_ID=
