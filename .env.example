# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# In Cloud Build, these are supplied via substitution variables and
# Secret Manager (see cloudbuild.yaml).
# ─────────────────────────────────────────────────────────────────────────────

# OAuth 2.0 Web Client ID from Google Cloud Console → APIs & Services →
# Credentials → "OAuth 2.0 Client IDs" (type: Web application).
# Format: <project-number>-<hash>.apps.googleusercontent.com
# Do NOT use a service account email here.
VITE_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Google Cloud Project NUMBER (not the project ID/name).
# Used by the Google Drive Picker (setAppId).
# Find it in Google Cloud Console → Home → Project info → Project number.
# Example: 371023911193
VITE_GOOGLE_APP_ID=your-project-number

# Google API Key from Google Cloud Console → APIs & Services → Credentials.
# Restrict it to the Drive API and your app's origin.
VITE_GOOGLE_API_KEY=your-api-key

# Gemini API Key from Google AI Studio (aistudio.google.com).
VITE_GEMINI_API_KEY=your-gemini-api-key

# Google Cloud Storage bucket name for uploads.
VITE_GCS_BUCKET=your-gcs-bucket-name

# Google Cloud Project ID (the string ID, not the number).
# Used for GCP Error Reporting.
VITE_GCP_PROJECT_ID=your-gcp-project-id

# Optional: Google Drive folder ID to use as the default location in the
# Drive Picker. Leave blank (or omit) to start at the Drive root.
VITE_REC_FOLDER_ID=
