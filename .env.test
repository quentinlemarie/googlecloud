# Test-only placeholder values – NOT real credentials.
# These are committed so that `vitest` can import modules that call requireEnv()
# without throwing during the test run.
VITE_GOOGLE_CLIENT_ID=test-client-id
VITE_GOOGLE_APP_ID=test-app-id
VITE_GOOGLE_API_KEY=test-api-key
VITE_GEMINI_API_KEY=test-gemini-key
VITE_GCP_PROJECT_ID=test-project
VITE_GCS_BUCKET=test-bucket
VITE_REC_FOLDER_ID=test-folder-id
